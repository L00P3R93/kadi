RewriteEngine On

RemoveLanguage .br

AddType application/javascript .js
AddType application/wasm .wasm
AddType application/octet-stream .pck

# Mark precompressed requests and stop other compression filters
RewriteCond %{HTTP:Accept-Encoding} br
RewriteCond %{REQUEST_URI} \.(js|wasm|pck)$ [NC]
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.br -f
RewriteRule ^ %{REQUEST_URI}.br [L,E=no-gzip:1,E=no-brotli:1]

<IfModule mod_headers.c>
    <FilesMatch "\.js\.br$">
        Header always set Content-Encoding br
        Header always set Content-Type application/javascript
        Header always unset Content-Language
        Header always unset ETag
        Header always set Cache-Control "no-cache, no-transform"
        Header always set Vary "Accept-Encoding"
    </FilesMatch>

    <FilesMatch "\.wasm\.br$">
        Header always set Content-Encoding br
        Header always set Content-Type application/wasm
        Header always unset Content-Language
        Header always unset ETag
        Header always set Cache-Control "no-cache, no-transform"
        Header always set Vary "Accept-Encoding"
    </FilesMatch>

    <FilesMatch "\.pck\.br$">
        Header always set Content-Encoding br
        Header always set Content-Type application/octet-stream
        Header always unset Content-Language
        Header always unset ETag
        Header always set Cache-Control "no-cache, no-transform"
        Header always set Vary "Accept-Encoding"
    </FilesMatch>
</IfModule>

<IfModule mod_setenvif.c>
    SetEnvIfNoCase Request_URI \.br$ no-gzip=1
    SetEnvIfNoCase Request_URI \.br$ no-brotli=1
</IfModule>

<IfModule mod_deflate.c>
    SetEnv no-gzip 1
</IfModule>

<IfModule mod_brotli.c>
    SetEnv no-brotli 1
</IfModule>

FileETag None
